# Postgres connection string (Neon, Supabase, Render Postgres, Vercel Postgres, etc.)
# Neon/Supabase example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Get this from https://console.anthropic.com  (Settings -> API Keys)
ANTHROPIC_API_KEY=
# Optional: override the model used for research/writing. Check
# https://docs.claude.com/en/docs/about-claude/models for current options.
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional but recommended once deployed: Vercel auto-populates this for you
# when it detects the cron job in vercel.json. Copy that value here too so
# the route can verify requests are really coming from Vercel's scheduler.
# Leave blank while developing locally.
CRON_SECRET=
